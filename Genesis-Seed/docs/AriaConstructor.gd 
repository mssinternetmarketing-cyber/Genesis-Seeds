# _redraw_edges — static editor draw (no animation)
# ══════════════════════════════════════════════════════════════════════════════
func _redraw_edges(nodes_data: Dictionary) -> void:
	if edge_mesh == null:
		return
	var verts  := PackedVector3Array()
	var colors := PackedColorArray()
	for edge in edge_list:
		var nA   : String  = edge[0]
		var nB   : String  = edge[1]
		var posA : Vector3 = node_positions.get(nA, Vector3.ZERO)
		var posB : Vector3 = node_positions.get(nB, Vector3.ZERO)
		var col  : Color   = COLOR_SPOKE if (nA == "Aria" or nB == "Aria") else COLOR_EDGE_DIM
		col.a = 0.35
		verts.append(posA);  colors.append(col)
		verts.append(posB);  colors.append(col)
	edge_mesh.clear_surfaces()
	if verts.size() == 0:
		return
	var arrays := []
	arrays.resize(Mesh.ARRAY_MAX)
	arrays[Mesh.ARRAY_VERTEX] = verts
	arrays[Mesh.ARRAY_COLOR]  = colors
	edge_mesh.add_surface_from_arrays(Mesh.PRIMITIVE_LINES, arrays)


