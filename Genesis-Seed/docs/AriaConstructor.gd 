# Public diagnostic — call from an attached script or the debugger console
# ══════════════════════════════════════════════════════════════════════════════
func print_bone_diagnostic() -> void:
	if aria_skeleton == null:
		print("[AriaGlobe] No Skeleton3D found — run _setup_aria_body() first.")
		return
	var n : int = aria_skeleton.get_bone_count()
	print("[AriaGlobe] Bone diagnostic — count: ", n)
	for i in n:
		var bone_name   : String = aria_skeleton.get_bone_name(i)
		var rest_pose   : Transform3D = aria_skeleton.get_bone_rest(i)
		var parent_idx  : int    = aria_skeleton.get_bone_parent(i)
		var parent_name : String = aria_skeleton.get_bone_name(parent_idx) if parent_idx >= 0 else "ROOT"
		print("  [%d] %s  ←  %s   pos: %s" % [
			i, bone_name, parent_name,
			str(rest_pose.origin.snapped(Vector3(0.001, 0.001, 0.001)))
		])